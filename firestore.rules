rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return signedIn() && userDoc().data != null;
    }

    function currentUser() {
      return userDoc().data;
    }

    function isActive() {
      return userExists() && (
        (currentUser().ativo == true || currentUser().active == true) &&
        currentUser().deleted != true
      );
    }

    function roleValue() {
      return currentUser().tipo != null ? currentUser().tipo : currentUser().role;
    }

    function isAdmin() {
      return isActive() && (
        roleValue() == "Gerente" ||
        roleValue() == "Administrador"
      );
    }

    function canUsers() {
      return isAdmin() ||
        currentUser().permissoes.usuarios == true ||
        currentUser().permissions.hasAny(["users"]);
    }

    function canProducts() {
      return isAdmin() ||
        currentUser().permissoes.produtos == true ||
        currentUser().permissoes.estoque == true ||
        currentUser().permissions.hasAny(["products"]);
    }

    function canSales() {
      return isAdmin() ||
        currentUser().permissoes.vendas == true ||
        currentUser().permissions.hasAny(["sales"]);
    }

    function canReports() {
      return isAdmin() ||
        currentUser().permissoes.relatorios == true ||
        currentUser().permissions.hasAny(["reports"]);
    }

    function canDeliveries() {
      return isAdmin() ||
        currentUser().permissoes.tele_entregas == true ||
        currentUser().permissions.hasAny(["deliveries"]);
    }

    function canSettings() {
      return isAdmin() ||
        currentUser().permissoes.configuracoes == true ||
        currentUser().permissions.hasAny(["settings"]);
    }

    match /users/{userId} {
      allow read: if isActive() && (request.auth.uid == userId || canUsers());
      allow create: if signedIn();
      allow update: if isActive() && (request.auth.uid == userId || canUsers());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isActive() && (canProducts() || canSales() || canReports());
      allow create, update: if isActive() && canProducts();
      allow delete: if false;
    }

    match /sales/{saleId} {
      allow read: if isActive() && (canSales() || canReports());
      allow create, update: if isActive() && canSales();
      allow delete: if false;
    }

    match /deliveries/{deliveryId} {
      allow read: if isActive() && canDeliveries();
      allow create, update: if isActive() && canDeliveries();
      allow delete: if false;
    }

    match /settings/{docId} {
      allow read, write: if isActive() && canSettings();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
